# SUPREME V5 Enterprise - Docker Compose production/homologation example
# Copy to .env and replace every placeholder with environment-specific values.
# Never commit .env or any file containing real secrets.

# Datastores used by docker-compose.production.yml
POSTGRES_PASSWORD=CHANGE_ME_SUPREME_POSTGRES_HEX_32
SENTINELA_POSTGRES_PASSWORD=CHANGE_ME_SENTINELA_POSTGRES_HEX_32
REDIS_PASSWORD=CHANGE_ME_REDIS_HEX_32

# Runtime sizing
SUPREME_API_WORKERS=2
SUPREME_WORKER_REPLICAS=2

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_HEX_32
GRAFANA_ROOT_URL=https://sentinela.example.org/grafana/

# Optional: used by scripts/backup_postgres.sh when exported in the shell.
# Keep this outside git and rotate it with the backup policy.
BACKUP_PASSPHRASE=CHANGE_ME_LONG_BACKUP_PASSPHRASE

# Prometheus reads the SUPREME bearer token from:
# infra/prometheus/supreme-api-token.local
# Its content must match supreme-backend/.env.production API_SECRET_KEY.
