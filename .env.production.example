# SUPREME V5 Enterprise — Docker Compose production/homologation environment
# Copy to .env and replace every placeholder before starting the stack.
# Never commit .env or any file containing real secrets.
#
# Usage:
#   cp .env.production.example .env
#   # edit .env with real values
#   docker compose -f docker-compose.production.yml up -d --build

# ── Datastores ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_SUPREME_POSTGRES_HEX_32
SENTINELA_POSTGRES_PASSWORD=CHANGE_ME_SENTINELA_POSTGRES_HEX_32
REDIS_PASSWORD=CHANGE_ME_REDIS_HEX_32

# ── SUPREME API secrets ───────────────────────────────────────────────────────
# API_INGEST_TOKEN — Bearer token for event ingest and psychometric form submit.
#   Referenced in docker-compose.local.yml as ${API_INGEST_TOKEN}.
#   Must match API_INGEST_TOKEN in supreme-backend/.env.production.
API_INGEST_TOKEN=CHANGE_ME_64_BYTE_HEX_INGEST_TOKEN

# ── Pseudonymisation salt ─────────────────────────────────────────────────────
# SUPREME_SALT links functional IDs to SHA-256 hashes.
# Referenced in docker-compose.local.yml as ${SUPREME_SALT}.
# Store OFFLINE. Never in git, chat, tickets or automated backups.
# Must match SUPREME_SALT in supreme-backend/.env.production.
SUPREME_SALT=CHANGE_ME_64_BYTE_HEX_OFFLINE_SALT

# ── Watcher / IPED integration ────────────────────────────────────────────────
# Path on host to the directory containing supreme_audit.ndjson.
# Referenced in docker-compose.local.yml as ${IPED_AUDIT_DIR}.
IPED_AUDIT_DIR=C:/Users/CHANGE_ME_USERNAME

# ── Runtime sizing ────────────────────────────────────────────────────────────
SUPREME_API_WORKERS=2
SUPREME_WORKER_REPLICAS=2

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_HEX_32
GRAFANA_ROOT_URL=https://sentinela.example.org/grafana/

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_PASSPHRASE=CHANGE_ME_LONG_BACKUP_PASSPHRASE

# ── Prometheus ────────────────────────────────────────────────────────────────
# Bearer token file: infra/prometheus/supreme-api-token.local (gitignored)
# Must match API_SECRET_KEY in supreme-backend/.env.production.
# Create with: echo -n "YOUR_API_SECRET_KEY" > infra/prometheus/supreme-api-token.local
