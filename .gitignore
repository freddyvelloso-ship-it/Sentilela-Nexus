# ── Secrets and environment files ─────────────────────────────────────────────
.env
*.env
.env.*
.envrc
!.env.example
!.env.production.example
**/.env
**/.env.production
**/.env.local
**/.env.*.local
**/secrets/
**/secrets.*
**/*secret*.local
**/*token*.local

# ── TLS / private keys ────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
certs/*.crt
**/privkey.pem
!certs/README.md

# ── Prometheus bearer token file (create manually, never commit) ──────────────
infra/prometheus/supreme-api-token.local

# ── Archives (may contain secrets or sensitive build output) ──────────────────
# Note: SUPREME_FINAL_LIMPO_PARA_CODEX_DEV.zip is tracked for historical
# reference but contains only .env.example files — no real secrets.
# Future archives must not be committed.
*.zip
*.tar.gz
*.tar.bz2

# ── Build artifacts ───────────────────────────────────────────────────────────
# _patch_build/ contains pre-compiled IPED patch binaries tracked intentionally.
# Add _patch_build/ below to stop tracking future builds.
*.class

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
.venv/
.venv*/
**/.venv/
.pytest_cache/
**/.pytest_cache/
*.egg-info/

# ── Node / frontend build ─────────────────────────────────────────────────────
node_modules/
dist/
build/

# ── Logs and audit data ───────────────────────────────────────────────────────
*.log
logs/
audit.ndjson
supreme_audit.ndjson
*.sqlite
*.sqlite3
*.db
backups/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
