# SENTINELA — production/homologation environment
# Copy to .env.production and replace every CHANGE_ME value before starting.
# DATABASE_URL is overridden at runtime by docker-compose.production.yml.

ENVIRONMENT=production
ENABLE_DOCS=false
# AUTO_INIT_DB=false is mandatory for production — migrations are applied externally.
AUTO_INIT_DB=false

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_SENTINELA_POSTGRES_HEX_32
DATABASE_URL=postgresql+asyncpg://sentinela:CHANGE_ME_SENTINELA_POSTGRES_HEX_32@sentinela-db:5432/sentinela

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_64_BYTE_HEX_JWT_SECRET
SUPREME_API_KEY=CHANGE_ME_64_BYTE_HEX_SHARED_WITH_SUPREME

# BOOTSTRAP_TOKEN — one-time token for POST /sentinela/api/auth/bootstrap
# with header X-Bootstrap-Token. REMOVE after the master user is created.
BOOTSTRAP_TOKEN=CHANGE_ME_TEMPORARY_BOOTSTRAP_TOKEN

# ── Session ───────────────────────────────────────────────────────────────────
ALGORITHM=HS256
# 43200 = 30 days — recommended for long-running field research sessions.
# Use 480 (8h) for higher-security environments.
ACCESS_TOKEN_EXPIRE_MINUTES=43200
ALLOWED_ORIGINS=https://sentinela.example.org
